# =============================================================================
# Example — copy values into env/.env.local | .env.dev | .env.qa | .env.prod
# DigitalOcean Inference Router example from Model Studio:
#   URL:   https://inference.do-ai.run/v1/chat/completions
#   model: router:shadow-mode-llm-evaluator
#   auth:  Bearer <MODEL_ACCESS_KEY>
# Our Go service uses stream=false (full JSON) so it can compare outputs.
# =============================================================================

APP_ENV=local
ADDR=:8080
GIN_MODE=debug
LOG_LEVEL=info

PRIMARY_LLM_URL=
CANDIDATE_LLM_URL=
PRIMARY_MODEL=
CANDIDATE_MODEL=
MODEL_ACCESS_KEY=

SHADOW_TIMEOUT_SECONDS=30
SHADOW_MAX_INFLIGHT=32
HTTP_CLIENT_TIMEOUT_SECONDS=30
