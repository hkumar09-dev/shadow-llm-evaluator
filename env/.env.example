# =============================================================================
# Example env file — copy inside env/ as .env.local / .env.dev / .env.qa / .env.prod
# Select with:  APP_ENV=local go run .     → loads env/.env.local
# Or override:  ENV_FILE=env/.env.local go run .
#               ENV_DIR=env APP_ENV=dev go run .
# =============================================================================

# Which environment this file represents (local | dev | qa | prod)
APP_ENV=local

# HTTP server
ADDR=:8080
GIN_MODE=debug

# Logging: debug | info | warn | error
LOG_LEVEL=info

# LLM endpoints — leave EMPTY to use in-process simulators
PRIMARY_LLM_URL=
CANDIDATE_LLM_URL=

# Shadow evaluation tuning
SHADOW_TIMEOUT_SECONDS=30
SHADOW_MAX_INFLIGHT=32

# HTTP client timeout when calling remote LLMs
HTTP_CLIENT_TIMEOUT_SECONDS=30
