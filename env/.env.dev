# Development environment — typically shared remote LLM stubs / internal services
APP_ENV=dev

ADDR=:8080
GIN_MODE=debug
LOG_LEVEL=debug

# Point these at your dev LLM gateways (or leave empty to keep using simulators)
PRIMARY_LLM_URL=http://primary-llm.dev.internal/v1/chat
CANDIDATE_LLM_URL=http://candidate-llm.dev.internal/v1/chat

SHADOW_TIMEOUT_SECONDS=30
SHADOW_MAX_INFLIGHT=64
HTTP_CLIENT_TIMEOUT_SECONDS=30
