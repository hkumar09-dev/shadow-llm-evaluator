# QA — DigitalOcean Inference
APP_ENV=qa

ADDR=:8080
GIN_MODE=release
LOG_LEVEL=info

PRIMARY_LLM_URL=https://inference.do-ai.run/v1/chat/completions
CANDIDATE_LLM_URL=https://inference.do-ai.run/v1/chat/completions

PRIMARY_MODEL=deepseek-4-flash
CANDIDATE_MODEL=glm-5.1

MODEL_ACCESS_KEY=YOUR_MODEL_ACCESS_KEY

SHADOW_TIMEOUT_SECONDS=45
SHADOW_MAX_INFLIGHT=64
HTTP_CLIENT_TIMEOUT_SECONDS=20
