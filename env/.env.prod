# Production environment — real endpoints required; tighter logging & release mode
APP_ENV=prod

ADDR=:8080
GIN_MODE=release
LOG_LEVEL=info

PRIMARY_LLM_URL=https://primary-llm.prod.internal/v1/chat
CANDIDATE_LLM_URL=https://candidate-llm.prod.internal/v1/chat

SHADOW_TIMEOUT_SECONDS=30
SHADOW_MAX_INFLIGHT=128
HTTP_CLIENT_TIMEOUT_SECONDS=30
