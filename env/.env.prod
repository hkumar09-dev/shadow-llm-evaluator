# Production — DigitalOcean Inference
APP_ENV=prod

ADDR=:8080
GIN_MODE=release
LOG_LEVEL=info

PRIMARY_LLM_URL=https://inference.do-ai.run/v1/chat/completions
CANDIDATE_LLM_URL=https://inference.do-ai.run/v1/chat/completions

PRIMARY_MODEL=router:shadow-mode-llm-evaluator
CANDIDATE_MODEL=router:shadow-mode-llm-evaluator

# Set the real key in DigitalOcean App Platform secrets (do not commit real keys)
MODEL_ACCESS_KEY=YOUR_MODEL_ACCESS_KEY

SHADOW_TIMEOUT_SECONDS=30
SHADOW_MAX_INFLIGHT=128
HTTP_CLIENT_TIMEOUT_SECONDS=60
